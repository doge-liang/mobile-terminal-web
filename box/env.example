# /root/.config/box/env —— 复制后填实值,chmod 600
BOX_NODE=term1
# push=主节点(term1,凭证以它为准) pull=其余节点
BOX_GLOBALS_ROLE=push
BOX_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
BOX_BUCKET=<bucket-name>
AWS_ACCESS_KEY_ID=<R2 API token 的 Access Key ID>
AWS_SECRET_ACCESS_KEY=<R2 API token 的 Secret>
# openssl rand -base64 24 生成;丢失 = 快照全部不可读,务必另行备份
RESTIC_PASSWORD=<restic 仓库口令>
# 本节点默认单盒内存上限(meta.json 的 memory_max 可按盒覆盖)
BOX_MEMORY_MAX=1500M
