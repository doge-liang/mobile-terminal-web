#!/usr/bin/env node
'use strict';
// box——agent 工作沙盒 CLI:bwrap 隔离 + restic→R2 迁移 + Nix 环境
// 子命令实现随任务推进逐个填充;未实现的先报错占位
const fs = require('fs');
const metaMod = require('../lib/meta');
const runtime = require('../lib/runtime');
const snapMod = require('../lib/snapshot');
const globalsMod = require('../lib/globals');
const { evaluateLease } = require('../lib/lease');
const { pickNode } = require('../lib/sched');
const { isValidBoxName } = require('../lib/mounts');
const { run, ssh } = require('../lib/sh');
const { loadConfig, hostFor } = require('../lib/env');
const { formatBoxesJson } = require('../lib/lsjson');

const USAGE = `用法: box <命令> [参数]
  ls [--json]                列出全部沙盒(--json 供程序解析)
  track <名> [路径]           登记现有目录为沙盒(默认 /root/<名>)
  up <名> [--node N] [--force]  拉起沙盒(自动调度节点)
  attach <名>                接入盒内 tmux
  exec <名> -- <命令...>      在盒内执行一次性命令
  park <名>                  快照归档并释放本节点
  snapshot [<名>|--active]   手动快照(--active=本机全部活跃盒并续租)
  globals <push|pull|auto>   全局配置同步
  prune                      按保留策略清理旧快照
  drop <名>                  删除沙盒的 R2 数据(交互确认)
  status                     本机视角状态`;

function parseArgs(argv) {
  const args = { _: [], flags: {}, rest: [] };
  for (let i = 0; i < argv.length; i++) {
    const a = argv[i];
    if (a === '--') { args.rest = argv.slice(i + 1); break; }
    if (a.startsWith('--')) {
      const k = a.slice(2);
      if (k === 'node') args.flags.node = argv[++i];
      else args.flags[k] = true;
    } else args._.push(a);
  }
  return args;
}

function probeAll(cfg) {
  return cfg.nodes.map((n) => {
    try {
      const out = n.host === 'local'
        ? fs.readFileSync('/proc/meminfo', 'utf8')
        : ssh(n.host, 'cat /proc/meminfo', { timeoutMs: 3000 }).stdout;
      const m = /MemAvailable:\s+(\d+)/.exec(out);
      return { name: n.name, memKb: m ? Number(m[1]) : null };
    } catch { return { name: n.name, memKb: null }; }
  });
}

function mustMeta(cfg, name) {
  if (!name) throw new Error('缺少沙盒名');
  const m = metaMod.readMeta(cfg, name);
  if (!m) throw new Error(`未知沙盒 ${name}(先 box track)`);
  return m;
}

const notYet = (name) => () => { throw new Error(`${name}: 尚未实现`); };
const cmds = {
  track: (cfg, args) => {
    const name = args._[0];
    if (!name) throw new Error('用法: box track <名> [路径]');
    if (!isValidBoxName(name)) throw new Error(`非法沙盒名 ${name}:仅允许字母数字 . _ -,不含 ..`);
    const p = args._[1] || `/root/${name}`;
    if (!fs.existsSync(p)) throw new Error(`路径不存在: ${p}`);
    if (metaMod.readMeta(cfg, name)) throw new Error(`沙盒 ${name} 已存在`);
    const meta = metaMod.newMeta({ name, path: p, node: cfg.node });
    if (fs.existsSync(`${p}/.auth-secret`)) {
      meta.pin = cfg.node;
      console.error(`警告: 检测到 .auth-secret——已排除快照,并 pin 到 ${cfg.node}(防止调度到他机覆盖部署)`);
    }
    snapMod.backupBox(cfg, meta);
    meta.last_snapshot = metaMod.iso();
    metaMod.writeMeta(cfg, name, meta);
    console.log(`已跟踪 ${name}(${p});当前在 ${cfg.node}。box attach ${name} 进入沙盒`);
  },

  up: (cfg, args) => {
    const name = args._[0];
    const meta = mustMeta(cfg, name);
    if (!args.flags.local) {
      const picked = args.flags.node ? { name: args.flags.node }
        : pickNode(probeAll(cfg), { pin: meta.pin, self: cfg.node });
      if (picked.warning) console.error(`警告: ${picked.warning}`);
      if (picked.name !== cfg.node) {
        const host = hostFor(cfg, picked.name);
        console.log(`调度到 ${picked.name},远程拉起…`);
        ssh(host, `box up ${name} --local${args.flags.force ? ' --force' : ''}`, { inherit: true, timeoutMs: 600000 });
        console.log(`完成。接入: ssh -t ${host} box attach ${name},或打开该节点的 term 页`);
        return;
      }
    }
    const lease = evaluateLease(meta, cfg.node, Date.now(), !!args.flags.force);
    if (!lease.ok) throw new Error(lease.reason);
    if (lease.reason) console.error(`注意: ${lease.reason}`);
    const freshHere = meta.leased_by === cfg.node && fs.existsSync(meta.path);
    if (!freshHere) snapMod.restoreBox(cfg, meta); // 母鸡重启场景:租约在本机+文件在盘=跳过 restore
    meta.leased_by = cfg.node;
    meta.lease_ts = metaMod.iso();
    metaMod.writeMeta(cfg, name, meta);
    runtime.startSandbox(cfg, meta);
    console.log(`${name} 已在 ${cfg.node} 拉起;box attach ${name} 接入`);
  },

  park: (cfg, args) => {
    const name = args._[0];
    const meta = mustMeta(cfg, name);
    if (meta.leased_by !== cfg.node) throw new Error(`租约不在本机(${meta.leased_by || '已归档'})`);
    snapMod.backupBox(cfg, meta);
    meta.last_snapshot = metaMod.iso();
    meta.leased_by = null;
    meta.lease_ts = null;
    metaMod.writeMeta(cfg, name, meta);
    runtime.stopSandbox(name);
    console.log(`${name} 已归档(快照上传、租约释放、沙盒停止)`);
  },

  ls: (cfg, args) => {
    const names = metaMod.listBoxNames(cfg);
    const metas = names.map((n) => metaMod.readMeta(cfg, n)).filter(Boolean);
    if (args.flags.json) {
      const running = metas
        .filter((m) => m.leased_by === cfg.node && runtime.isRunning(m.name))
        .map((m) => m.name);
      return void console.log(JSON.stringify(formatBoxesJson(metas, running)));
    }
    if (!names.length) return void console.log('(无沙盒;box track 开始)');
    for (const m of metas) {
      const state = m.leased_by ? `active@${m.leased_by}` : 'parked';
      const local = m.leased_by === cfg.node && runtime.isRunning(m.name) ? ' [运行中]' : '';
      const pin = m.pin ? ` pin=${m.pin}` : '';
      console.log(`${m.name.padEnd(24)} ${state}${local}${pin}  快照:${m.last_snapshot || '无'}`);
    }
  },

  attach: (cfg, args) => {
    const name = args._[0];
    const meta = mustMeta(cfg, name);
    if (meta.leased_by !== cfg.node) throw new Error(`租约在 ${meta.leased_by || '无'}——先 box up ${name}`);
    if (!runtime.isRunning(name)) runtime.startSandbox(cfg, meta);
    return runtime.attach(name, meta);
  },

  exec: (cfg, args) => {
    const name = args._[0];
    if (!name || !args.rest.length) throw new Error('用法: box exec <名> -- <命令...>');
    return runtime.execIn(name, mustMeta(cfg, name), args.rest);
  },

  snapshot: (cfg, args) => {
    if (!args.flags.active && !args._[0]) {
      throw new Error('用法: box snapshot <名> 或 box snapshot --active');
    }
    const names = args.flags.active
      ? metaMod.listBoxNames(cfg).filter((n) => {
          const m = metaMod.readMeta(cfg, n);
          return m && m.leased_by === cfg.node;
        })
      : [args._[0]];
    if (!names.length) { // --active 且本机无活跃盒:无事可做,非错误(定时器每轮都会碰到)
      console.log('本机无活跃盒,跳过快照');
      return;
    }
    for (const n of names) {
      const m = metaMod.readMeta(cfg, n);
      if (!m) throw new Error(`未知沙盒 ${n}`);
      snapMod.backupBox(cfg, m);
      m.last_snapshot = metaMod.iso();
      if (m.leased_by === cfg.node) m.lease_ts = metaMod.iso(); // 快照即续租
      metaMod.writeMeta(cfg, n, m);
      console.log(`已快照 ${n}`);
    }
  },

  globals: (cfg, args) => {
    const sub = args._[0];
    if (!['push', 'pull', 'auto'].includes(sub)) throw new Error('用法: box globals <push|pull|auto>');
    globalsMod[sub](cfg);
    console.log(`globals ${sub} 完成`);
  },

  prune: (cfg) => {
    run('restic', ['forget', '--keep-hourly', '24', '--keep-daily', '7', '--keep-weekly', '4', '--prune'],
      { env: cfg.resticEnv, inherit: true });
  },

  drop: (cfg, args) => {
    const name = args._[0];
    if (name && !isValidBoxName(name)) throw new Error(`非法沙盒名 ${name}:仅允许字母数字 . _ -,不含 ..`);
    const meta = mustMeta(cfg, name);
    if (meta.leased_by) throw new Error(`沙盒活跃于 ${meta.leased_by},先 park 再 drop`);
    const rl = require('readline').createInterface({ input: process.stdin, output: process.stdout });
    rl.question(`确认删除沙盒 ${name} 的全部 R2 数据?输入 yes: `, (ans) => {
      rl.close();
      if (ans.trim() !== 'yes') return void console.log('已取消');
      try {
        const snapsR = run('restic', ['snapshots', '--tag', `box:${name}`, '--json'],
          { env: cfg.resticEnv, check: false });
        if (snapsR.status !== 0) {
          const tail = (snapsR.stderr || '').trim().split('\n').pop();
          throw new Error(`列出待删快照失败: ${tail || 'unknown'}`);
        }
        // 列举失败必须在这里中止,不能吞成 []——否则下面 forget 会被跳过但 rclone purge
        // 仍会执行,meta 已删却在 R2 留下孤儿快照(restic 索引里还挂着,永不会被 prune 回收)。
        const snaps = JSON.parse(snapsR.stdout || '[]');
        if (snaps.length) run('restic', ['forget', ...snaps.map((s) => s.id)], { env: cfg.resticEnv, inherit: true });
        run('rclone', ['purge', `BOXR2:${cfg.bucket}/boxes/${name}`], { env: cfg.rcloneEnv });
        console.log(`${name} 已删除`);
      } catch (e) {
        console.error(`box: ${e.message}`);
        process.exitCode = 1;
      }
    });
  },

  status: (cfg) => {
    const { run } = require('../lib/sh');
    console.log(`节点: ${cfg.node}(globals ${cfg.globalsRole})  内存默认上限: ${cfg.memoryMax}`);
    const r2 = run('rclone', ['lsd', `BOXR2:${cfg.bucket}`], { env: cfg.rcloneEnv, check: false, timeoutMs: 10000 });
    console.log(`R2 连通: ${r2.status === 0 ? 'ok' : '失败 ' + r2.stderr.trim().split('\n').pop()}`);
    const snaps = run('restic', ['snapshots', '--json'], { env: cfg.resticEnv, check: false, timeoutMs: 30000 });
    console.log(`restic 快照数: ${snaps.status === 0 ? JSON.parse(snaps.stdout || '[]').length : '不可达'}`);
    const timer = run('systemctl', ['is-active', 'box-snapshot.timer'], { check: false });
    console.log(`定时快照: ${timer.stdout.trim() || 'unknown'}`);
    const units = run('systemctl', ['list-units', '--plain', '--no-legend', 'boxrun-*.service'], { check: false });
    const act = units.stdout.trim();
    console.log(`本机活跃盒:\n${act || '  (无)'}`);
  },
};

const [cmd, ...rest] = process.argv.slice(2);
if (!cmd || cmd === '--help' || cmd === '-h' || !cmds[cmd]) {
  console.log(USAGE);
  process.exit(cmd && cmd !== '--help' && cmd !== '-h' ? 1 : 0);
}
try {
  process.exitCode = cmds[cmd](loadConfig(), parseArgs(rest)) || 0;
} catch (e) {
  console.error(`box: ${e.message}`);
  process.exit(1);
}

module.exports = { parseArgs };
